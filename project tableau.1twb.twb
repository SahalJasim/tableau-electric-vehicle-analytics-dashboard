      <column caption='0-100 km/h (sec)' datatype='real' name='[Acceleration_0_100_kmh_sec]' role='measure' type='quantitative' />
      <column caption='Avg Speed (kmh)' datatype='real' name='[Avg_Speed_kmh]' role='measure' type='quantitative' />
      <column caption='Battery Capacity (kWh)' datatype='real' name='[Battery_Capacity_kWh]' role='measure' type='quantitative' />
