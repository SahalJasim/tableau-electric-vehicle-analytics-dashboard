      <column caption='CO2 Saved tons' datatype='real' name='[CO2_Saved_tons]' role='measure' type='quantitative' />
      <column caption='Charging Efficiency' datatype='real' name='[Calculation_0268073317703680]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Range_km] / [Battery_Capacity_kWh]' />
      </column>
      <column caption='Total Annual Cost' datatype='real' name='[Calculation_0268073317986305]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Monthly_Charging_Cost_USD] * 12) + [Maintenance_Cost_USD] + [Insurance_Cost_USD]' />
      </column>
      <column caption='Vehicle Age' datatype='integer' name='[Calculation_0268073318092802]' role='measure' type='quantitative'>
